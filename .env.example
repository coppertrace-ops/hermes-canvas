# Hermes Canvas — environment template (ATLAS-owned).
#
# Copy to `.env.local` (git-ignored) for local dev. NEVER put real secrets in this
# file — it is committed. Secrets live in provider dashboards / `npx convex env set`.
# Schema + validation for every variable below lives in packages/env.

# ---------------------------------------------------------------------------
# Public (browser-exposed via Next.js NEXT_PUBLIC_*). No secrets here — ever.
# ---------------------------------------------------------------------------

# Convex deployment client URL (…convex.cloud). From `npx convex dev` output.
NEXT_PUBLIC_CONVEX_URL="https://your-deployment-name.convex.cloud"

# Origins (no trailing slash). Local dev defaults shown.
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_CONTENT_ORIGIN="http://localhost:3001"

# UI-only demo banner hint. Grants NO access; real gate is server-side.
NEXT_PUBLIC_DEMO_MODE="false"

# ---------------------------------------------------------------------------
# Next.js server (non-secret). Provider secrets live in Convex, not here.
# ---------------------------------------------------------------------------

# Convex deployment identifier used by the Convex CLI (e.g. "dev:name" / "prod:name").
CONVEX_DEPLOYMENT=""

# Local/demo auth bypass. Honored ONLY when NODE_ENV != "production". Leave "false"
# (or unset) everywhere except a throwaway local/demo run.
DEMO_AUTH_BYPASS="false"

# ---------------------------------------------------------------------------
# Convex deployment env — set with `npx convex env set <NAME> <value>`, NOT here.
# Listed for reference only; schema in packages/env/src/convex.ts.
# ---------------------------------------------------------------------------

# OWNER_EMAIL            = you@example.com          # closed-owner allowlist-of-one
# OWNER_BOOTSTRAP_SECRET = <256-bit token>          # one-time: authorizes first owner sign-up, then UNSET it
# HERMES_SERVICE_TOKEN   = <256-bit token>          # bearer for the Hermes host, hashed at rest
# APP_ORIGIN             = https://your-app.vercel.app
# CONTENT_ORIGIN         = https://your-content.vercel.app
# SITE_URL               = https://your-deployment.convex.site
# JWT_PRIVATE_KEY / JWKS = <provisioned once by `npx @convex-dev/auth` — see docs/runbook.md>
